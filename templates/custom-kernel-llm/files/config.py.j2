from dataclasses import dataclass


@dataclass
class GPTConfig:
    vocab_size: int = 50257
    max_len: int = {{.MaxLen}}
    d_model: int = {{.DModel}}
    n_heads: int = {{.NHeads}}
    n_layers: int = {{.NLayers}}
    dropout: float = {{.Dropout}}

    lr: float = {{.Lr}}
    weight_decay: float = {{.WeightDecay}}
    batch_size: int = {{.BatchSize}}
    epochs: int = {{.Epochs}}
    warmup_steps: int = {{.WarmupSteps}}

    kernel_backend: str = "{{.KernelBackend}}"
    compile_model: bool = {{if .CompileModel}}True{{else}}False{{end}}
    use_flash_attn: bool = {{if .UseFlashAttn}}True{{else}}False{{end}}

    device: str = "{{.Device}}"
    seed: int = {{.Seed}}

    def __post_init__(self):
        if self.device == "auto":
            import torch

            if torch.cuda.is_available():
                self.device = "cuda"
            elif hasattr(torch.backends, "mps") and torch.backends.mps.is_available():
                self.device = "mps"
            else:
                self.device = "cpu"


GPT2_SMALL = GPTConfig(d_model=768, n_heads=12, n_layers=12)
GPT2_MEDIUM = GPTConfig(d_model=1024, n_heads=16, n_layers=24)
GPT2_LARGE = GPTConfig(d_model=1280, n_heads=20, n_layers=36)
GPT2_XL = GPTConfig(d_model=1600, n_heads=25, n_layers=48)
GPT_DEBUG = GPTConfig(d_model=64, n_heads=4, n_layers=2, max_len=64, batch_size=4)
