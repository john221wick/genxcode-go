import os
import torch
import torch.distributed as dist

from .config import EP_CONFIG


def setup_distributed():
    rank = int(os.environ.get("RANK", 0))
    local_rank = int(os.environ.get("LOCAL_RANK", 0))
    world_size = int(os.environ.get("WORLD_SIZE", EP_CONFIG["ep_size"]))

    dist.init_process_group(
        backend=EP_CONFIG["backend"],
        rank=rank,
        world_size=world_size,
    )

    torch.cuda.set_device(local_rank)
    return rank, local_rank, world_size


def create_ep_group(world_size, ep_size):
    """Create expert-parallel process groups."""
    ep_groups = []
    for i in range(0, world_size, ep_size):
        ranks = list(range(i, i + ep_size))
        group = dist.new_group(ranks)
        ep_groups.append((ranks, group))

    my_rank = dist.get_rank()
    for ranks, group in ep_groups:
        if my_rank in ranks:
            return group

    raise RuntimeError(f"Rank {my_rank} not found in any EP group")


def cleanup_distributed():
    if dist.is_initialized():
        dist.destroy_process_group()


def is_main_rank():
    return not dist.is_initialized() or dist.get_rank() == 0
