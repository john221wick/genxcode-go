#include <cuda_runtime.h>

#include <cmath>
#include <iostream>
#include <vector>

__global__ void {{ .KernelName }}(
    const float* a,
    const float* b,
    float* out,
    int size
) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx < size) {
        out[idx] = a[idx] + b[idx];
    }
}

int main() {
    constexpr int kSize = {{ .VectorSize }};
    constexpr int kBlockSize = {{ .BlockSize }};
    const int grid_size = (kSize + kBlockSize - 1) / kBlockSize;

    std::vector<float> host_a(kSize, 1.0f);
    std::vector<float> host_b(kSize, 2.0f);
    std::vector<float> host_out(kSize, 0.0f);

    float* dev_a = nullptr;
    float* dev_b = nullptr;
    float* dev_out = nullptr;

    cudaMalloc(&dev_a, kSize * sizeof(float));
    cudaMalloc(&dev_b, kSize * sizeof(float));
    cudaMalloc(&dev_out, kSize * sizeof(float));

    cudaMemcpy(dev_a, host_a.data(), kSize * sizeof(float), cudaMemcpyHostToDevice);
    cudaMemcpy(dev_b, host_b.data(), kSize * sizeof(float), cudaMemcpyHostToDevice);

    {{ .KernelName }}<<<grid_size, kBlockSize>>>(dev_a, dev_b, dev_out, kSize);

    cudaError_t launch_error = cudaGetLastError();
    if (launch_error != cudaSuccess) {
        std::cerr << "Kernel launch failed: " << cudaGetErrorString(launch_error) << "\n";
        return 1;
    }

    cudaDeviceSynchronize();
    cudaMemcpy(host_out.data(), dev_out, kSize * sizeof(float), cudaMemcpyDeviceToHost);

    bool valid = true;
    for (int i = 0; i < kSize; ++i) {
        if (std::fabs(host_out[i] - 3.0f) > 1e-5f) {
            valid = false;
            std::cerr << "Validation failed at index " << i << "\n";
            break;
        }
    }

    cudaFree(dev_a);
    cudaFree(dev_b);
    cudaFree(dev_out);

    if (!valid) {
        return 1;
    }

    std::cout << "Kernel {{ .KernelName }} completed successfully on " << kSize << " elements.\n";
    return 0;
}
