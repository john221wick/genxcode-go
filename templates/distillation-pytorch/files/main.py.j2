import torch

from src.config import STUDENT_CONFIG, TRAINING_CONFIG
from src.student_model import GPTModel
from src.tokenizer_setup import get_tokenizer
from src.teacher_api import TeacherAPI
from src.data_collection import collect_teacher_data, save_data
from src.train import train_student
from src.generate import generate_text
{{ if eq .Technique "rejection_sampling" }}from src.rejection_sampling import rejection_sampling
{{ end }}{{ if eq .Technique "feedback_loop" }}from src.feedback_loop import feedback_loop_train
{{ end }}

SAMPLE_PROMPTS = [
    "Explain what a hash table is.",
    "What causes rain?",
    "Write a Python function to reverse a linked list.",
    "What is the difference between a stack and a queue?",
    "Explain gradient descent in simple terms.",
]


def main():
    tokenizer = get_tokenizer()
    student = GPTModel(STUDENT_CONFIG)
    teacher = TeacherAPI()

    print(f"Student params: {sum(p.numel() for p in student.parameters()):,}")
    print(f"Teacher: {{ .TeacherProvider }}/{{ .TeacherModel }}")
    print(f"Technique: {{ .Technique }}")
{{ if eq .Technique "sft" }}

    # ── Response-Based Distillation (SFT) ──
    # Simplest approach: teacher generates responses, student imitates via cross-entropy.
    print("\n--- Collecting teacher data ---")
    teacher_data = collect_teacher_data(SAMPLE_PROMPTS, teacher, use_cot=False)
    save_data(teacher_data, "teacher_responses.json")
    print(f"Collected {len(teacher_data)} examples")

    print("\n--- Training student (SFT) ---")
    student = train_student(student, teacher_data, tokenizer)
{{ else if eq .Technique "cot" }}

    # ── Chain-of-Thought Distillation ──
    # Teacher shows full reasoning trace. Student learns intermediate steps.
    # This is the technique DeepSeek used for their distilled R1 models.
    print("\n--- Collecting teacher data (with chain-of-thought) ---")
    teacher_data = collect_teacher_data(SAMPLE_PROMPTS, teacher, use_cot=True)
    save_data(teacher_data, "teacher_cot_responses.json")
    print(f"Collected {len(teacher_data)} CoT examples")

    print("\n--- Training student on reasoning traces ---")
    student = train_student(student, teacher_data, tokenizer)
{{ else if eq .Technique "rejection_sampling" }}

    # ── Rejection Sampling with Teacher-as-Judge ──
    # Phase 1: Initial SFT to give student basic competence
    print("\n--- Phase 1: Collecting teacher data for initial SFT ---")
    teacher_data = collect_teacher_data(SAMPLE_PROMPTS, teacher, use_cot=False)
    save_data(teacher_data, "teacher_responses.json")

    print("\n--- Phase 1: Training student (initial SFT) ---")
    student = train_student(student, teacher_data, tokenizer)

    # Phase 2: Student generates candidates, teacher scores, keep best
    print("\n--- Phase 2: Rejection sampling ---")
    refined_data = rejection_sampling(student, SAMPLE_PROMPTS, teacher, tokenizer)
    save_data(refined_data, "refined_responses.json")
    print(f"Refined {len(refined_data)} examples")

    print("\n--- Phase 2: Fine-tuning on best responses ---")
    student = train_student(student, refined_data, tokenizer)
{{ else if eq .Technique "feedback_loop" }}

    # ── Feedback Loop Distillation (RL-flavored) ──
    # Phase 1: Initial SFT for baseline competence
    print("\n--- Phase 1: Collecting teacher data for initial SFT ---")
    teacher_data = collect_teacher_data(SAMPLE_PROMPTS, teacher, use_cot=False)
    save_data(teacher_data, "teacher_responses.json")

    print("\n--- Phase 1: Training student (initial SFT) ---")
    student = train_student(student, teacher_data, tokenizer)

    # Phase 2: Iterative feedback loop — student generates, teacher critiques
    print("\n--- Phase 2: Feedback loop ({{ .RlVariant }} variant) ---")
    student = feedback_loop_train(student, SAMPLE_PROMPTS, teacher, tokenizer)
{{ end }}

    # Save model
    torch.save(student.state_dict(), "distilled_student.pt")
    print("\nModel saved to distilled_student.pt")

    # Test generation
    print("\n--- Test Generation ---")
    test_prompt = "Explain what a neural network is."
    output = generate_text(student, tokenizer, test_prompt, max_new_tokens=128)
    print(f"Prompt: {test_prompt}")
    print(f"Student: {output}")


if __name__ == "__main__":
    main()
