import torch
import torch.nn.functional as F

from .config import STUDENT_CONFIG


def generate_text(model, tokenizer, prompt, max_new_tokens=256, temperature=1.0):
    """Autoregressive generation from student model."""
    model.eval()
    device = next(model.parameters()).device
    input_ids = tokenizer.encode(prompt)
    input_ids = torch.tensor([input_ids], device=device)

    with torch.no_grad():
        for _ in range(max_new_tokens):
            idx_cond = input_ids[:, -STUDENT_CONFIG["context_length"]:]
            logits = model(idx_cond)
            logits = logits[:, -1, :] / temperature
            probs = F.softmax(logits, dim=-1)
            next_id = torch.multinomial(probs, num_samples=1)
            input_ids = torch.cat([input_ids, next_id], dim=1)

            if next_id.item() == tokenizer.eos_token_id:
                break

    generated = tokenizer.decode(input_ids[0].tolist())
    return generated[len(prompt):].strip()
