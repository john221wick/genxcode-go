import torch
from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig
{{ if .UseLora }}
from peft import LoraConfig, get_peft_model, prepare_model_for_kbit_training
{{ end }}

from .config import MODEL_CONFIG


def load_tokenizer():
    tokenizer = AutoTokenizer.from_pretrained(MODEL_CONFIG["model_name"])
    if tokenizer.pad_token is None:
        tokenizer.pad_token = tokenizer.eos_token
        tokenizer.pad_token_id = tokenizer.eos_token_id
    return tokenizer


def _get_quantization_config():
{{ if .LoadIn4bit }}
    return BitsAndBytesConfig(
        load_in_4bit=True,
        bnb_4bit_quant_type=MODEL_CONFIG["bnb_4bit_quant_type"],
        bnb_4bit_compute_dtype=getattr(torch, MODEL_CONFIG["bnb_4bit_compute_dtype"]),
        bnb_4bit_use_double_quant=True,
    )
{{ else if .LoadIn8bit }}
    return BitsAndBytesConfig(load_in_8bit=True)
{{ else }}
    return None
{{ end }}


def _load_base_model(model_name):
    quant_config = _get_quantization_config()
    kwargs = {"device_map": "auto", "torch_dtype": torch.bfloat16}
    if quant_config:
        kwargs["quantization_config"] = quant_config
    return AutoModelForCausalLM.from_pretrained(model_name, **kwargs)


{{ if .UseLora }}
def _get_lora_config():
    return LoraConfig(
        r=MODEL_CONFIG["lora_r"],
        lora_alpha=MODEL_CONFIG["lora_alpha"],
        lora_dropout=MODEL_CONFIG["lora_dropout"],
        target_modules=MODEL_CONFIG["lora_target_modules"],
        bias="none",
        task_type="CAUSAL_LM",
    )
{{ end }}


def load_model():
    model = _load_base_model(MODEL_CONFIG["model_name"])
{{ if .UseLora }}
{{ if or .LoadIn4bit .LoadIn8bit }}
    model = prepare_model_for_kbit_training(model)
{{ end }}
    model = get_peft_model(model, _get_lora_config())
    model.print_trainable_parameters()
{{ end }}
    if MODEL_CONFIG["gradient_checkpointing"]:
        model.gradient_checkpointing_enable()
    return model


{{ if or (eq .RlVariant "dpo") (eq .RlVariant "kto") }}
def load_ref_model():
{{ if .RefModelName }}
    return _load_base_model(MODEL_CONFIG["ref_model_name"])
{{ else }}
    return None
{{ end }}
{{ end }}

{{ if eq .RlVariant "ppo" }}
def load_reward_model():
{{ if .RewardModelName }}
    from transformers import AutoModelForSequenceClassification
    return AutoModelForSequenceClassification.from_pretrained(
        MODEL_CONFIG["reward_model_name"],
        device_map="auto",
        torch_dtype=torch.bfloat16,
    )
{{ else }}
    raise ValueError("reward_model_name is required for PPO")
{{ end }}
{{ end }}
