import os
import requests

from .config import TEACHER_CONFIG


class TeacherAPI:
    """Wraps LLM API into a uniform interface for distillation."""

    def __init__(self):
        self.provider = TEACHER_CONFIG["provider"]
        self.model = TEACHER_CONFIG["model"]
        self.temperature = TEACHER_CONFIG["temperature"]
        self.max_tokens = TEACHER_CONFIG["max_tokens"]
{{ if eq .TeacherProvider "anthropic" }}
        self.api_key = os.environ.get("ANTHROPIC_API_KEY", "")
        self.base_url = "https://api.anthropic.com/v1"
{{ else if eq .TeacherProvider "google" }}
        self.api_key = os.environ.get("GOOGLE_API_KEY", "")
        self.base_url = "https://generativelanguage.googleapis.com/v1beta"
{{ else }}
        self.api_key = os.environ.get("OPENAI_API_KEY", "")
        self.base_url = "https://api.openai.com/v1"
{{ end }}
        if not self.api_key:
            raise ValueError(
                "API key not found. Set the appropriate environment variable: "
{{ if eq .TeacherProvider "anthropic" }}
                "ANTHROPIC_API_KEY"
{{ else if eq .TeacherProvider "google" }}
                "GOOGLE_API_KEY"
{{ else }}
                "OPENAI_API_KEY"
{{ end }}
            )

    def generate(self, prompt, temperature=None, max_tokens=None):
        temp = temperature if temperature is not None else self.temperature
        tokens = max_tokens if max_tokens is not None else self.max_tokens
{{ if eq .TeacherProvider "anthropic" }}
        resp = requests.post(
            f"{self.base_url}/messages",
            headers={
                "x-api-key": self.api_key,
                "content-type": "application/json",
                "anthropic-version": "2023-06-01",
            },
            json={
                "model": self.model,
                "max_tokens": tokens,
                "messages": [{"role": "user", "content": prompt}],
                "temperature": temp,
            },
        )
        resp.raise_for_status()
        return resp.json()["content"][0]["text"]
{{ else if eq .TeacherProvider "google" }}
        resp = requests.post(
            f"{self.base_url}/models/{self.model}:generateContent",
            headers={"Content-Type": "application/json"},
            params={"key": self.api_key},
            json={
                "contents": [{"parts": [{"text": prompt}]}],
                "generationConfig": {"temperature": temp, "maxOutputTokens": tokens},
            },
        )
        resp.raise_for_status()
        return resp.json()["candidates"][0]["content"]["parts"][0]["text"]
{{ else }}
        resp = requests.post(
            f"{self.base_url}/chat/completions",
            headers={"Authorization": f"Bearer {self.api_key}"},
            json={
                "model": self.model,
                "messages": [{"role": "user", "content": prompt}],
                "temperature": temp,
                "max_tokens": tokens,
            },
        )
        resp.raise_for_status()
        return resp.json()["choices"][0]["message"]["content"]
{{ end }}

    def score(self, question, response):
        scoring_prompt = (
            f"Rate this response 1-10 for accuracy and quality.\n"
            f"Return ONLY a number.\n\n"
            f"Question: {question}\nResponse: {response}"
        )
        try:
            result = self.generate(scoring_prompt, temperature=0)
            return int(result.strip())
        except (ValueError, KeyError):
            return 5
