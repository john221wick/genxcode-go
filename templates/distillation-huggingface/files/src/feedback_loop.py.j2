from .config import TRAINING_CONFIG
from .generate import generate_text
from .train import train_student


def feedback_loop_train(model, prompts, teacher, tokenizer):
    """Iterative feedback: student generates, teacher critiques, retrain."""
    n_iterations = TRAINING_CONFIG["n_iterations"]
{{ if eq .RlVariant "dpo" }}

    for iteration in range(n_iterations):
        print(f"\n  Feedback iteration {iteration + 1}/{n_iterations} (DPO-style)")
        training_data = []

        for i, prompt in enumerate(prompts):
            student_response = generate_text(model, tokenizer, prompt, max_new_tokens=256, temperature=0.8)

            critique_prompt = (
                f"Provide a corrected, improved version of this response.\n\n"
                f"Question: {prompt}\n"
                f"Student response: {student_response}\n\n"
                f"Corrected response:"
            )
            corrected = teacher.generate(critique_prompt, temperature=0.3)
            training_data.append({"prompt": prompt, "response": corrected})

        model = train_student(model, training_data, tokenizer)
{{ else }}

    n_candidates = TRAINING_CONFIG["n_candidates"]
    keep_top = TRAINING_CONFIG["keep_top"]

    for iteration in range(n_iterations):
        print(f"\n  Feedback iteration {iteration + 1}/{n_iterations} (GRPO-style)")
        training_data = []

        for i, prompt in enumerate(prompts):
            candidates = []
            for _ in range(n_candidates):
                response = generate_text(model, tokenizer, prompt, max_new_tokens=256, temperature=1.0)
                score = teacher.score(prompt, response)
                candidates.append((response, score))

            candidates.sort(key=lambda x: x[1], reverse=True)
            for response, score in candidates[:keep_top]:
                training_data.append({"prompt": prompt, "response": response})

        model = train_student(model, training_data, tokenizer)
{{ end }}

    return model
