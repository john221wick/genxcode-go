import torch
import torch.nn.functional as F

from .config import MODEL_CONFIG, TRAINING_CONFIG, TP_CONFIG
from .model import TPTransformer
from .distributed import setup_distributed, create_tp_group, cleanup_distributed, is_main_rank
from .data import RandomTokenDataset, create_dataloader


def get_precision_dtype():
    precision = TRAINING_CONFIG["precision"]
    if precision == "bf16":
        return torch.bfloat16
    elif precision == "fp16":
        return torch.float16
    return torch.float32


def train():
    rank, local_rank, world_size = setup_distributed()
    device = torch.device(f"cuda:{local_rank}")

    tp_group = create_tp_group(world_size, TP_CONFIG["tp_size"])

    model = TPTransformer(tp_group).to(device)
    optimizer = torch.optim.AdamW(model.parameters(), lr=TRAINING_CONFIG["lr"], weight_decay=0.1)

    dtype = get_precision_dtype()
    grad_accum_steps = TRAINING_CONFIG["gradient_accumulation_steps"]
    vocab_size = MODEL_CONFIG["vocab_size"]

    dataset = RandomTokenDataset()
    loader = create_dataloader(dataset)

    for epoch in range(TRAINING_CONFIG["epochs"]):
        model.train()
        total_loss = 0.0

        for micro_step, batch in enumerate(loader):
            input_ids = batch["input_ids"].to(device)
            labels = batch["labels"].to(device)

            with torch.autocast(device_type="cuda", dtype=dtype):
                logits = model(input_ids)
                shift_logits = logits[:, :-1, :].contiguous()
                shift_labels = labels[:, 1:].contiguous()
                loss = F.cross_entropy(
                    shift_logits.view(-1, vocab_size),
                    shift_labels.view(-1),
                    ignore_index=-100,
                )
                loss = loss / grad_accum_steps

            loss.backward()

            if (micro_step + 1) % grad_accum_steps == 0:
                torch.nn.utils.clip_grad_norm_(model.parameters(), TRAINING_CONFIG["max_grad_norm"])
                optimizer.step()
                optimizer.zero_grad()

            total_loss += loss.item() * grad_accum_steps

        avg_loss = total_loss / max(len(loader), 1)
        if is_main_rank():
            print(f"[TP] Epoch {epoch + 1}/{TRAINING_CONFIG['epochs']} | Loss: {avg_loss:.4f}")

    if is_main_rank():
        torch.save(model.state_dict(), "model_tp.pt")
        print("Saved model_tp.pt")

    cleanup_distributed()
